# ==================== IDE 配置（必须忽略） ====================
.idea/                # PyCharm等JetBrains IDE的本地配置
*.iml
*.iws
*.ipr
.vscode/               # 若用VSCode可补充

# ==================== Python 打包/缓存（必须忽略） ====================
__pycache__/           # Python字节码缓存
*.py[cod]
*$py.class
*.egg-info/            # 打包生成的元数据（匹配你的mini_agent.egg-info/）
dist/
build/
*.egg
MANIFEST

# ==================== 虚拟环境（必须忽略） ====================
.venv/
venv/
env/
ENV/

# ==================== 环境变量（必须忽略） ====================
.env
.env.*