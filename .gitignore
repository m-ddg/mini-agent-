# ==================== IDE 配置（必须忽略） ====================
# PyCharm等JetBrains IDE的本地配置
.idea/
*.iml
*.iws
*.ipr
# 若用VSCode可补充
.vscode/

# ==================== Python 打包/缓存（必须忽略） ====================
# Python字节码缓存
__pycache__/
*.py[cod]
*$py.class
# 打包生成的元数据（匹配你的mini_agent.egg-info/）
*.egg-info/
dist/
build/
*.egg
MANIFEST

# ==================== 虚拟环境（必须忽略） ====================
.venv/
venv/
env/
ENV/

# ==================== 环境变量（必须忽略） ====================
.env
.env.*